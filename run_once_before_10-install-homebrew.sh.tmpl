#!/bin/bash
# Step 0 — runs BEFORE chezmoi applies any dotfiles. Installs the prerequisites
# the secret templates depend on:
#   - Xcode Command Line Tools (git, compilers)
#   - Rosetta 2 (Apple Silicon)
#   - Homebrew
#   - 1Password desktop app + CLI (op), then waits until op can authenticate so
#     the ssh/Forge templates render on the first pass.
set -euo pipefail

echo "==> Xcode Command Line Tools"
if ! xcode-select -p >/dev/null 2>&1; then
  xcode-select --install || true
  echo "Complete the CLT install, then re-run chezmoi."
  exit 1
fi

# Warm the sudo credential cache so the NONINTERACTIVE Homebrew install (and
# Rosetta / cask installs) don't fail with "Need sudo access". Also fails fast
# with a clear message if this user isn't an admin.
echo "==> Caching sudo credentials (you must be an Administrator)"
if ! sudo -v; then
  echo "ERROR: '$USER' needs admin rights. Make it an Administrator in" >&2
  echo "System Settings > Users & Groups, then re-run chezmoi." >&2
  exit 1
fi

{{ if eq .chezmoi.arch "arm64" -}}
echo "==> Rosetta 2"
if ! /usr/bin/pgrep -q oahd; then
  softwareupdate --install-rosetta --agree-to-license
fi
{{ end -}}

echo "==> Homebrew"
if ! command -v brew >/dev/null 2>&1; then
  NONINTERACTIVE=1 /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi
eval "$({{ if eq .chezmoi.arch "arm64" }}/opt/homebrew/bin/brew{{ else }}/usr/local/bin/brew{{ end }} shellenv)"

echo "==> 1Password (desktop app + CLI)"
if [ ! -d "/Applications/1Password.app" ]; then
  brew install --cask 1password
fi
if ! command -v op >/dev/null 2>&1; then
  brew install --cask 1password-cli
fi

# Secret templates render right after this script, so op must be able to read
# now. Check ONCE (stdin from /dev/null so op can't drop into an interactive
# prompt that wedges the terminal). If it can't, print setup steps and stop
# cleanly — fix 1Password, then re-run `chezmoi apply`.
if ! op vault list </dev/null >/dev/null 2>&1; then
  cat <<'MSG' >&2

==> 1Password CLI isn't ready, so secrets can't render yet. Set it up:
      1. Open 1Password and sign in.
      2. Settings -> Developer -> enable BOTH
         "Integrate with 1Password CLI" and "Use the SSH agent".
      3. Quit 1Password (Cmd-Q) and REOPEN it — the toggles only activate
         after a restart. Make sure it's unlocked.
      4. Verify in a terminal:  op vault list   (should list your vaults)
   Then re-run:  chezmoi apply

MSG
  exit 1
fi
echo "==> 1Password CLI ready."
