[user]
    name = {{ .name | quote }}
    email = {{ .email | quote }}

[init]
    defaultBranch = main

[core]
    editor = code --wait
    pager = delta
    excludesfile = ~/.gitignore_global
    autocrlf = input
    whitespace = fix

[interactive]
    diffFilter = delta --color-only

[delta]
    navigate = true
    line-numbers = true
    side-by-side = false
    syntax-theme = Dracula

[merge]
    conflictstyle = diff3

[diff]
    colorMoved = default

[color]
    ui = auto

[pull]
    rebase = true

[push]
    default = current
    autoSetupRemote = true

[fetch]
    prune = true

[rebase]
    autoStash = true

[alias]
    # Status
    s = status -sb
    st = status

    # Logging
    lg = log --graph --pretty=format:'%Cred%h%Creset -%C(yellow)%d%Creset %s %Cgreen(%cr) %C(bold blue)<%an>%Creset' --abbrev-commit
    last = log -1 HEAD --stat
    history = log --oneline --graph --decorate -20

    # Branches
    br = branch
    branches = branch -a
    co = checkout
    cob = checkout -b

    # Commits
    cm = commit -m
    ca = commit --amend
    can = commit --amend --no-edit

    # Diff
    d = diff
    ds = diff --staged
    dt = difftool

    # Stash
    sl = stash list
    sp = stash pop
    ss = stash save

    # Undo
    undo = reset --soft HEAD~1
    unstage = reset HEAD --

    # Cleanup
    cleanup = "!git branch --merged | grep -v '\\*\\|main\\|master' | xargs -n 1 git branch -d"

[credential]
    helper = osxkeychain

[filter "lfs"]
    clean = git-lfs clean -- %f
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true

# Optional machine-local / work overrides (not managed by chezmoi)
[include]
    path = ~/.gitconfig.local
