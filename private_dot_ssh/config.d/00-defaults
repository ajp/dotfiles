# =============================================================================
# SSH Defaults
# =============================================================================

Host *
    # Use macOS Keychain for passphrases
    UseKeychain yes
    AddKeysToAgent yes
    IdentityFile ~/.ssh/id_ed25519
    IdentityFile ~/.ssh/id_rsa

    # Connection settings
    ServerAliveInterval 60
    ServerAliveCountMax 3

    # Security
    IdentitiesOnly yes
