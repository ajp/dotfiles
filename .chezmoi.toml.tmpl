{{- $name := promptStringOnce . "name" "Full name" -}}
{{- $email := promptStringOnce . "email" "Git email" -}}

[data]
    name = {{ $name | quote }}
    email = {{ $email | quote }}

# 1Password: secret templates use `op`. Sign in with `op signin` (or enable the
# 1Password app's CLI integration) before `chezmoi apply` so they can render.
[onepassword]
    mode = "account"
